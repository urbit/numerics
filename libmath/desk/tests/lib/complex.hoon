/+  *test, complex
::::  /tests/lib/complex -- complex arithmetic over IEEE-754 components
::
::  @cs packs two @rs (real low, imag high); expected values from NumPy
::  complex64.  1+2i=0x4000.0000.3f80.0000, 3+4i=0x4080.0000.4040.0000.
::  @cd packs two @rd; values from NumPy complex128.  1+2i packs to
::  0x4000.0000.0000.0000.3ff0.0000.0000.0000, 3+4i to
::  0x4010.0000.0000.0000.4008.0000.0000.0000.
::
^|
|%
::  --- complex-single (@cs) ---
++  test-cs-components  ^-  tang
  ;:  weld
    %+  expect-eq  !>(`@rs`.1)  !>((~(re cs:complex %n) 0x4000.0000.3f80.0000))   ::  re(1+2i)=1
    %+  expect-eq  !>(`@rs`.2)  !>((~(im cs:complex %n) 0x4000.0000.3f80.0000))   ::  im(1+2i)=2
    %+  expect-eq  !>(`@`0x4000.0000.3f80.0000)  !>((~(pak cs:complex %n) .1 .2))  ::  1+2i
    %+  expect-eq  !>(`@`0x0)  !>(~(zero cs:complex %n))
  ==
++  test-cs-arith  ^-  tang
  ;:  weld
    %+  expect-eq  !>(`@`0x40c0.0000.4080.0000)
      !>((~(add cs:complex %n) 0x4000.0000.3f80.0000 0x4080.0000.4040.0000))   ::  (1+2i)+(3+4i)=4+6i
    %+  expect-eq  !>(`@`0xc000.0000.c000.0000)
      !>((~(sub cs:complex %n) 0x4000.0000.3f80.0000 0x4080.0000.4040.0000))   ::  =-2-2i
    %+  expect-eq  !>(`@`0x4120.0000.c0a0.0000)
      !>((~(mul cs:complex %n) 0x4000.0000.3f80.0000 0x4080.0000.4040.0000))   ::  =-5+10i
    %+  expect-eq  !>(`@`0x4000.0000)
      !>((~(div cs:complex %n) 0x4000.0000.4000.0000 0x3f80.0000.3f80.0000))   ::  (2+2i)/(1+1i)=2
  ==
++  test-cs-unary  ^-  tang
  ;:  weld
    %+  expect-eq  !>(`@`0xc000.0000.bf80.0000)  !>((~(neg cs:complex %n) 0x4000.0000.3f80.0000))   ::  -(1+2i)
    %+  expect-eq  !>(`@`0xc000.0000.3f80.0000)  !>((~(conj cs:complex %n) 0x4000.0000.3f80.0000))  ::  conj=1-2i
    %+  expect-eq  !>(`@`0x40a0.0000)            !>((~(abs cs:complex %n) 0x4080.0000.4040.0000))   ::  |3+4i|=5
    %+  expect-eq  !>(`@`0x3f80.0000)            !>(~(one cs:complex %n))                            ::  1+0i
  ==
++  test-cs-compare  ^-  tang
  ;:  weld
    %+  expect-eq  !>(%.y)  !>((~(equ cs:complex %n) 0x4000.0000.3f80.0000 0x4000.0000.3f80.0000))
    %+  expect-eq  !>(%.n)  !>((~(equ cs:complex %n) 0x4000.0000.3f80.0000 0x4080.0000.4040.0000))
    %+  expect-eq  !>(%.y)  !>((~(neq cs:complex %n) 0x4000.0000.3f80.0000 0x4080.0000.4040.0000))
  ==
::  --- complex-double (@cd) ---
++  test-cd-components  ^-  tang
  ;:  weld
    %+  expect-eq  !>(`@rd`.~1)  !>((~(re cd:complex %n) 0x4000.0000.0000.0000.3ff0.0000.0000.0000))  ::  re(1+2i)=1
    %+  expect-eq  !>(`@rd`.~2)  !>((~(im cd:complex %n) 0x4000.0000.0000.0000.3ff0.0000.0000.0000))  ::  im(1+2i)=2
    %+  expect-eq  !>(`@`0x4000.0000.0000.0000.3ff0.0000.0000.0000)  !>((~(pak cd:complex %n) .~1 .~2))
    %+  expect-eq  !>(`@`0x0)  !>(~(zero cd:complex %n))
  ==
++  test-cd-arith  ^-  tang
  ;:  weld
    %+  expect-eq  !>(`@`0x4018.0000.0000.0000.4010.0000.0000.0000)
      !>  %-  ~(add cd:complex %n)
          :-  0x4000.0000.0000.0000.3ff0.0000.0000.0000
          0x4010.0000.0000.0000.4008.0000.0000.0000                            ::  (1+2i)+(3+4i)=4+6i
    %+  expect-eq  !>(`@`0xc000.0000.0000.0000.c000.0000.0000.0000)
      !>  %-  ~(sub cd:complex %n)
          :-  0x4000.0000.0000.0000.3ff0.0000.0000.0000
          0x4010.0000.0000.0000.4008.0000.0000.0000                            ::  =-2-2i
    %+  expect-eq  !>(`@`0x4024.0000.0000.0000.c014.0000.0000.0000)
      !>  %-  ~(mul cd:complex %n)
          :-  0x4000.0000.0000.0000.3ff0.0000.0000.0000
          0x4010.0000.0000.0000.4008.0000.0000.0000                            ::  =-5+10i
    %+  expect-eq  !>(`@`0x4000.0000.0000.0000)
      !>  %-  ~(div cd:complex %n)
          :-  0x4000.0000.0000.0000.4000.0000.0000.0000
          0x3ff0.0000.0000.0000.3ff0.0000.0000.0000                            ::  (2+2i)/(1+1i)=2
  ==
++  test-cd-unary  ^-  tang
  ;:  weld
    %+  expect-eq  !>(`@`0xc000.0000.0000.0000.bff0.0000.0000.0000)
      !>((~(neg cd:complex %n) 0x4000.0000.0000.0000.3ff0.0000.0000.0000))     ::  -(1+2i)
    %+  expect-eq  !>(`@`0xc000.0000.0000.0000.3ff0.0000.0000.0000)
      !>((~(conj cd:complex %n) 0x4000.0000.0000.0000.3ff0.0000.0000.0000))    ::  conj=1-2i
    %+  expect-eq  !>(`@`0x4014.0000.0000.0000)
      !>((~(abs cd:complex %n) 0x4010.0000.0000.0000.4008.0000.0000.0000))     ::  |3+4i|=5
    %+  expect-eq  !>(`@`0x3ff0.0000.0000.0000)  !>(~(one cd:complex %n))      ::  1+0i
  ==
++  test-cd-compare  ^-  tang
  ;:  weld
    %+  expect-eq  !>(%.y)
      !>  %-  ~(equ cd:complex %n)
          :-  0x4000.0000.0000.0000.3ff0.0000.0000.0000
          0x4000.0000.0000.0000.3ff0.0000.0000.0000
    %+  expect-eq  !>(%.n)
      !>  %-  ~(equ cd:complex %n)
          :-  0x4000.0000.0000.0000.3ff0.0000.0000.0000
          0x4010.0000.0000.0000.4008.0000.0000.0000
    %+  expect-eq  !>(%.y)
      !>  %-  ~(neq cd:complex %n)
          :-  0x4000.0000.0000.0000.3ff0.0000.0000.0000
          0x4010.0000.0000.0000.4008.0000.0000.0000
  ==
::  --- complex-half (@ch) ---  1+2i=0x4000.3c00, 3+4i=0x4400.4200
++  test-ch-components  ^-  tang
  ;:  weld
    %+  expect-eq  !>(`@rh`.~~1)  !>((~(re ch:complex %n) 0x4000.3c00))   ::  re(1+2i)=1
    %+  expect-eq  !>(`@rh`.~~2)  !>((~(im ch:complex %n) 0x4000.3c00))   ::  im(1+2i)=2
    %+  expect-eq  !>(`@`0x4000.3c00)  !>((~(pak ch:complex %n) .~~1 .~~2))
    %+  expect-eq  !>(`@`0x0)  !>(~(zero ch:complex %n))
  ==
++  test-ch-arith  ^-  tang
  ;:  weld
    %+  expect-eq  !>(`@`0x4600.4400)  !>((~(add ch:complex %n) 0x4000.3c00 0x4400.4200))   ::  =4+6i
    %+  expect-eq  !>(`@`0xc000.c000)  !>((~(sub ch:complex %n) 0x4000.3c00 0x4400.4200))   ::  =-2-2i
    %+  expect-eq  !>(`@`0x4900.c500)  !>((~(mul ch:complex %n) 0x4000.3c00 0x4400.4200))   ::  =-5+10i
    %+  expect-eq  !>(`@`0x4000)       !>((~(div ch:complex %n) 0x4000.4000 0x3c00.3c00))   ::  (2+2i)/(1+1i)=2
  ==
++  test-ch-unary  ^-  tang
  ;:  weld
    %+  expect-eq  !>(`@`0xc000.bc00)  !>((~(neg ch:complex %n) 0x4000.3c00))   ::  -(1+2i)
    %+  expect-eq  !>(`@`0xc000.3c00)  !>((~(conj ch:complex %n) 0x4000.3c00))  ::  conj=1-2i
    %+  expect-eq  !>(`@`0x4500)       !>((~(abs ch:complex %n) 0x4400.4200))   ::  |3+4i|=5
    %+  expect-eq  !>(`@`0x3c00)       !>(~(one ch:complex %n))                 ::  1+0i
  ==
++  test-ch-compare  ^-  tang
  ;:  weld
    %+  expect-eq  !>(%.y)  !>((~(equ ch:complex %n) 0x4000.3c00 0x4000.3c00))
    %+  expect-eq  !>(%.n)  !>((~(equ ch:complex %n) 0x4000.3c00 0x4400.4200))
    %+  expect-eq  !>(%.y)  !>((~(neq ch:complex %n) 0x4000.3c00 0x4400.4200))
  ==
::  --- complex-quad (@cq) ---
++  test-cq-components  ^-  tang
  ;:  weld
    %+  expect-eq  !>(`@rq`.~~~1)
      !>((~(re cq:complex %n) 0x4000.0000.0000.0000.0000.0000.0000.0000.3fff.0000.0000.0000.0000.0000.0000.0000))
    %+  expect-eq  !>(`@rq`.~~~2)
      !>((~(im cq:complex %n) 0x4000.0000.0000.0000.0000.0000.0000.0000.3fff.0000.0000.0000.0000.0000.0000.0000))
    %+  expect-eq  !>(`@`0x4000.0000.0000.0000.0000.0000.0000.0000.3fff.0000.0000.0000.0000.0000.0000.0000)
      !>((~(pak cq:complex %n) .~~~1 .~~~2))
    %+  expect-eq  !>(`@`0x0)  !>(~(zero cq:complex %n))
  ==
++  test-cq-arith  ^-  tang
  ;:  weld
    %+  expect-eq  !>(`@`0x4001.8000.0000.0000.0000.0000.0000.0000.4001.0000.0000.0000.0000.0000.0000.0000)
      !>  %-  ~(add cq:complex %n)
          :-  0x4000.0000.0000.0000.0000.0000.0000.0000.3fff.0000.0000.0000.0000.0000.0000.0000
          0x4001.0000.0000.0000.0000.0000.0000.0000.4000.8000.0000.0000.0000.0000.0000.0000           ::  =4+6i
    %+  expect-eq  !>(`@`0x4002.4000.0000.0000.0000.0000.0000.0000.c001.4000.0000.0000.0000.0000.0000.0000)
      !>  %-  ~(mul cq:complex %n)
          :-  0x4000.0000.0000.0000.0000.0000.0000.0000.3fff.0000.0000.0000.0000.0000.0000.0000
          0x4001.0000.0000.0000.0000.0000.0000.0000.4000.8000.0000.0000.0000.0000.0000.0000           ::  =-5+10i
    %+  expect-eq  !>(`@`0x4000.0000.0000.0000.0000.0000.0000.0000)
      !>  %-  ~(div cq:complex %n)
          :-  0x4000.0000.0000.0000.0000.0000.0000.0000.4000.0000.0000.0000.0000.0000.0000.0000
          0x3fff.0000.0000.0000.0000.0000.0000.0000.3fff.0000.0000.0000.0000.0000.0000.0000           ::  (2+2i)/(1+1i)=2
  ==
++  test-cq-unary  ^-  tang
  ;:  weld
    %+  expect-eq  !>(`@`0xc000.0000.0000.0000.0000.0000.0000.0000.3fff.0000.0000.0000.0000.0000.0000.0000)
      !>((~(conj cq:complex %n) 0x4000.0000.0000.0000.0000.0000.0000.0000.3fff.0000.0000.0000.0000.0000.0000.0000))
    %+  expect-eq  !>(`@`0x4001.4000.0000.0000.0000.0000.0000.0000)
      !>((~(abs cq:complex %n) 0x4001.0000.0000.0000.0000.0000.0000.0000.4000.8000.0000.0000.0000.0000.0000.0000))
    %+  expect-eq  !>(`@`0x3fff.0000.0000.0000.0000.0000.0000.0000)  !>(~(one cq:complex %n))
  ==
++  test-cq-extra  ^-  tang
  ;:  weld
    %+  expect-eq  !>(`@`0xc000.0000.0000.0000.0000.0000.0000.0000.c000.0000.0000.0000.0000.0000.0000.0000)
      !>  %-  ~(sub cq:complex %n)
          :-  0x4000.0000.0000.0000.0000.0000.0000.0000.3fff.0000.0000.0000.0000.0000.0000.0000
          0x4001.0000.0000.0000.0000.0000.0000.0000.4000.8000.0000.0000.0000.0000.0000.0000           ::  =-2-2i
    %+  expect-eq  !>(`@`0xc000.0000.0000.0000.0000.0000.0000.0000.bfff.0000.0000.0000.0000.0000.0000.0000)
      !>((~(neg cq:complex %n) 0x4000.0000.0000.0000.0000.0000.0000.0000.3fff.0000.0000.0000.0000.0000.0000.0000))   ::  -(1+2i)
    %+  expect-eq  !>(%.y)
      !>  %-  ~(equ cq:complex %n)
          :-  0x4000.0000.0000.0000.0000.0000.0000.0000.3fff.0000.0000.0000.0000.0000.0000.0000
          0x4000.0000.0000.0000.0000.0000.0000.0000.3fff.0000.0000.0000.0000.0000.0000.0000
    %+  expect-eq  !>(%.y)
      !>  %-  ~(neq cq:complex %n)
          :-  0x4000.0000.0000.0000.0000.0000.0000.0000.3fff.0000.0000.0000.0000.0000.0000.0000
          0x4001.0000.0000.0000.0000.0000.0000.0000.4000.8000.0000.0000.0000.0000.0000.0000
  ==
--
