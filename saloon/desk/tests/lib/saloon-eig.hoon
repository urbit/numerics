::  Tests for Saloon symmetric-Jacobi eigendecomposition (+eig).
::
::  GENERATED by saloon/tools/eig_check.py -- do not edit by hand.
::  Per matrix: A*V = V*diag(vals) (eigpair, order/sign free) and
::  sort(computed vals) = sort(eigh vals).  Oracle: numpy.linalg.eigh.
::
/-  ls=lagoon
/+  *test, *saloon, *lagoon
|%
++  sad  (sake %n .~1e-12)
::  closeness with absolute + relative floor sized for ~1e3 magnitudes.
++  close
  |=  [x=ray:ls y=ray:ls]
  ^-  ?
  (all:(lake %n) (is-close:(lake %n) x y [.~1e-6 .~1e-6]))
++  mk-diag
  |=  [vals=ray:ls n=@]
  ^-  ray:ls
  =/  z  (zeros:(lake %n) [~[n n] 6 %i754 ~])
  =/  i  0
  |-  ^-  ray:ls
  ?:  =(i n)  z
  =.  z  (set-item:(lake %n) z ~[i i] (get-item:(lake %n) vals ~[i]))
  $(i +(i))
::  ascending-sorted copy of a 1-D eigenvalue ray (Jacobi order is arbitrary).
++  sorted
  |=  [r=ray:ls n=@]
  ^-  ray:ls
  =/  lst=(list @)
    =/  i  0
    =/  acc=(list @)  ~
    |-  ^-  (list @)
    ?:  =(i n)  (flop acc)
    $(i +(i), acc [(get-item:(lake %n) r ~[i]) acc])
  =/  srt  (sort lst |=([p=@ q=@] (~(lth rd:math [%n .~1e-10]) p q)))
  (en-ray:(lake %n) [[~[n] 6 %i754 ~] srt])
++  eigpair-ok
  |=  [a=ray:ls n=@]
  ^-  ?
  =/  res  (eig:sad a)
  =/  av   (mmul:(lake %n) a vecs.res)
  =/  vd   (mmul:(lake %n) vecs.res (mk-diag vals.res n))
  (close av vd)
++  spectrum-ok
  |=  [a=ray:ls n=@ want=ray:ls]
  ^-  ?
  (close (sorted vals:(eig:sad a) n) want)
::  laplacian5: 5x5, eigenvalues [0.267949, 1.0, 2.0, 3.0, 3.732051]
++  m-laplacian5
  (en-ray:(lake %n) [[~[5 5] 6 %i754 ~] ~[~[.~2.0 .~-1.0 .~0 .~0 .~0] ~[.~-1.0 .~2.0 .~-1.0 .~0 .~0] ~[.~0 .~-1.0 .~2.0 .~-1.0 .~0] ~[.~0 .~0 .~-1.0 .~2.0 .~-1.0] ~[.~0 .~0 .~0 .~-1.0 .~2.0]]])
++  w-laplacian5
  (en-ray:(lake %n) [[~[5] 6 %i754 ~] ~[.~0.2679491924311228 .~1.0 .~1.9999999999999998 .~3.0 .~3.7320508075688776]])
++  test-eigpair-laplacian5   (expect !>((eigpair-ok m-laplacian5 5)))
++  test-spectrum-laplacian5  (expect !>((spectrum-ok m-laplacian5 5 w-laplacian5)))
::  rosser8: 8x8, eigenvalues [-1020.049018, -0.0, 0.098049, 1000.0, 1000.0, 1019.901951, 1020.0, 1020.049018]
++  m-rosser8
  (en-ray:(lake %n) [[~[8 8] 6 %i754 ~] ~[~[.~611.0 .~196.0 .~-192.0 .~407.0 .~-8.0 .~-52.0 .~-49.0 .~29.0] ~[.~196.0 .~899.0 .~113.0 .~-192.0 .~-71.0 .~-43.0 .~-8.0 .~-44.0] ~[.~-192.0 .~113.0 .~899.0 .~196.0 .~61.0 .~49.0 .~8.0 .~52.0] ~[.~407.0 .~-192.0 .~196.0 .~611.0 .~8.0 .~44.0 .~59.0 .~-23.0] ~[.~-8.0 .~-71.0 .~61.0 .~8.0 .~411.0 .~-599.0 .~208.0 .~208.0] ~[.~-52.0 .~-43.0 .~49.0 .~44.0 .~-599.0 .~411.0 .~208.0 .~208.0] ~[.~-49.0 .~-8.0 .~8.0 .~59.0 .~208.0 .~208.0 .~99.0 .~-911.0] ~[.~29.0 .~-44.0 .~52.0 .~-23.0 .~208.0 .~208.0 .~-911.0 .~99.0]]])
++  w-rosser8
  (en-ray:(lake %n) [[~[8] 6 %i754 ~] ~[.~-1020.0490184299958 .~-1.5626348849798314e-13 .~0.09804864072174323 .~1000.0 .~1000.0000000000007 .~1019.9019513592788 .~1020.0000000000005 .~1020.0490184299971]])
++  test-eigpair-rosser8   (expect !>((eigpair-ok m-rosser8 8)))
++  test-spectrum-rosser8  (expect !>((spectrum-ok m-rosser8 8 w-rosser8)))
::  wilkinson7: 7x7, eigenvalues [-1.124885, 0.267949, 1.0, 2.0, 2.363328, 3.732051, 3.761557]
++  m-wilkinson7
