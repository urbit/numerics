  (en-ray:(lake %n) [[~[7] 6 %i754 ~] ~[.~-1.1248854197645746 .~0.26794919243112253 .~0.9999999999999992 .~2.0000000000000004 .~2.363328237932683 .~3.7320508075688776 .~3.7615571818318907]])
++  test-eigpair-wilkinson7   (expect !>((eigpair-ok m-wilkinson7 7)))
++  test-spectrum-wilkinson7  (expect !>((spectrum-ok m-wilkinson7 7 w-wilkinson7)))
